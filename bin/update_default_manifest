#!/bin/bash -eu
# SPDX-FileCopyrightText: 2025 Uwe Fechner
# SPDX-License-Identifier: MIT

# Parse optional --version argument
version_override=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --version)
            shift
            if [[ $# -eq 0 ]]; then
                echo "Error: --version requires an argument (e.g. +1.11 or +1.12)"
                exit 1
            fi
            version_override="$1"
            shift
            ;;
        --help|-h)
            echo "Usage: $0 [--version +1.11|+1.12]"
            echo ""
            echo "Update one default manifest file for the RamAirKite.jl project."
            echo "Runs Pkg.update() on the main, examples, and test projects,"
            echo "then copies the resulting Manifest to the corresponding"
            echo "Manifest-v<version>.toml.default file and commits it."
            echo ""
            echo "Options:"
            echo "  --version +1.11|+1.12  Update manifest for a specific Julia version"
            echo "                         (default: use the currently active Julia version)"
            echo "  --help, -h             Show this help message"
            exit 0
            ;;
        *)
            echo "Error: Unknown argument: $1"
            echo "Usage: $0 [--version +1.11|+1.12]"
            echo "Try '$0 --help' for more information."
            exit 1
            ;;
    esac
done

if [[ $(basename $(pwd)) == "bin" ]]; then
    cd ..
fi

# determine the Julia version
if [[ -n "$version_override" ]]; then
    # Remove the leading '+'
    julia_major="${version_override:1}"
    echo "Using Julia version override: $julia_major"
else
    julia_version=$(julia --version | awk '{print($3)}')
    julia_major=${julia_version:0:3}
    if [[ $julia_major == "1.1" ]]; then
        julia_major=${julia_version:0:4}
    fi
    echo "Detected Julia version: $julia_major"
fi

# update the main project
julia --project=. -e 'using Pkg; Pkg.Registry.update(); Pkg.update()'
# update the example project
julia --project=examples -e 'using Pkg; Pkg.update()'
# update the test project
julia --project=test -e 'using Pkg; Pkg.update()'

# Normalize main manifest (Pkg.update may write Manifest.toml instead of versioned)
if [ ! -f "Manifest-v${julia_major}.toml" ] && [ -f "Manifest.toml" ]; then
    mv "Manifest.toml" "Manifest-v${julia_major}.toml"
    echo "Renamed Manifest.toml to Manifest-v${julia_major}.toml"
fi

if [[ $julia_major == "1.11" ]]; then
    # For Julia 1.11: use the examples manifest as the main default manifest
    # Normalize examples manifest name first
    if [ ! -f "examples/Manifest-v1.11.toml" ] && [ -f "examples/Manifest.toml" ]; then
        mv "examples/Manifest.toml" "examples/Manifest-v1.11.toml"
        echo "Renamed examples/Manifest.toml to examples/Manifest-v1.11.toml"
    fi
    # Copy examples manifest to main manifest
    cp "examples/Manifest-v1.11.toml" "Manifest-v1.11.toml"
    echo "Copied examples/Manifest-v1.11.toml to Manifest-v1.11.toml"
    # Make it the default
    cp "Manifest-v1.11.toml" "Manifest-v1.11.toml.default"
    echo "Copied Manifest-v1.11.toml to Manifest-v1.11.toml.default"
elif [[ $julia_major == "1.12" ]]; then
    # For Julia 1.12: copy main manifest to .default and delete all examples manifests
    cp "Manifest-v1.12.toml" "Manifest-v1.12.toml.default"
    echo "Copied Manifest-v1.12.toml to Manifest-v1.12.toml.default"
    rm -f examples/Manifest.toml examples/Manifest-v1.11.toml examples/Manifest-v1.12.toml examples/Manifest-v1.11.toml.default examples/Manifest-v1.12.toml.default
    echo "Deleted all manifest files in examples/"
fi

# Commit only the default manifest files
git add "Manifest-v${julia_major}.toml.default"
if git diff --cached --quiet; then
    echo "No changes to default manifests, nothing to commit."
else
    git commit -m "Update default manifest for Julia $julia_major"
    echo "Committed updated default manifest."
fi

echo "Done."
